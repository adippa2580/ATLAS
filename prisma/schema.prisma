// Atlas data model — see docs/architecture/atlas-system-design.md §3.1
// Every tenant-scoped row carries tenantId; Postgres RLS enforces isolation in prod.
// The affinity_evidence table is append-only and is the ONLY write path into the taste graph.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------
enum TenantKind {
  anchor
  venue
  alist
}

model Tenant {
  id        String     @id @default(uuid())
  name      String
  kind      TenantKind
  createdAt DateTime   @default(now())

  guests   Guest[]
  venues   Venue[]
  bookings Booking[]
  crews    Crew[]
}

// ---------------------------------------------------------------------------
// Guest hub — Identity & Profile
// ---------------------------------------------------------------------------
model Guest {
  id            String   @id @default(uuid())
  tenantId      String
  primaryPhone  String? // E.164
  email         String?
  displayName   String?
  provisional   Boolean  @default(true)
  walletPassId  String?  @unique
  globalGuestId String? // resolves this per-tenant guest to the cross-tenant identity spine
  createdAt     DateTime @default(now())

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  globalGuest  GlobalGuest?       @relation(fields: [globalGuestId], references: [id])
  links        IdentityLink[]
  consents     ConsentGrant[]
  evidence     AffinityEvidence[]
  affinities   GuestAffinity[]
  crewMembers  CrewMember[]
  bookings     Booking[]
  entitlements Entitlement[]

  @@index([tenantId])
  @@index([tenantId, primaryPhone])
  @@index([tenantId, email])
  @@index([globalGuestId])
}

enum IdentityLinkKind {
  phone
  email
  card_fingerprint
  spotify_id
  instagram_id
  wallet
}

model IdentityLink {
  id        String           @id @default(uuid())
  tenantId  String
  guestId   String
  kind      IdentityLinkKind
  valueHash String
  verified  Boolean          @default(false)
  source    String?
  createdAt DateTime         @default(now())

  guest Guest @relation(fields: [guestId], references: [id])

  @@unique([tenantId, kind, valueHash])
  @@index([tenantId, guestId])
}

// Append-only audit of merges (reversible)
model IdentityMergeLog {
  id          String   @id @default(uuid())
  tenantId    String
  survivingId String
  absorbedId  String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([tenantId, survivingId])
}

// ---------------------------------------------------------------------------
// Guest hub — Consent ledger (hard dependency of every evidence write)
// ---------------------------------------------------------------------------
enum ConsentBasis {
  connector_oauth
  checkout_terms
  explicit
  tenant_dpa
}

model ConsentGrant {
  id        String       @id @default(uuid())
  tenantId  String
  guestId   String
  scope     String
  basis     ConsentBasis
  connector String?
  grantedAt DateTime     @default(now())
  revokedAt DateTime?

  guest    Guest              @relation(fields: [guestId], references: [id])
  evidence AffinityEvidence[]

  @@index([tenantId, guestId])
}

// ---------------------------------------------------------------------------
// Guest hub — Taste graph: evidence (append-only) + derived affinity
// ---------------------------------------------------------------------------
enum SubjectType {
  artist
  genre
  venue
  event
  crew
  table
  product
}

enum Signal {
  follow
  listen
  book
  attend
  spend
  mute
  loyalty
}

enum Provenance {
  connector
  booking
  venue_link
  pos
  agent
}

model AffinityEvidence {
  id          String      @id @default(uuid())
  tenantId    String
  guestId     String
  subjectType SubjectType
  subjectRef  String
  signal      Signal
  weight      Float       @default(1)
  provenance  Provenance
  consentId   String?
  observedAt  DateTime    @default(now())
  dedupeKey   String

  guest   Guest         @relation(fields: [guestId], references: [id])
  consent ConsentGrant? @relation(fields: [consentId], references: [id])

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, guestId])
  @@index([tenantId, subjectType, subjectRef])
}

// Derived, decay-aware, mute-respecting taste. Recomputed from evidence.
model GuestAffinity {
  id          String      @id @default(uuid())
  tenantId    String
  guestId     String
  subjectType SubjectType
  subjectRef  String
  score       Float
  muted       Boolean     @default(false)
  decayedAt   DateTime    @default(now())

  guest Guest @relation(fields: [guestId], references: [id])

  @@unique([tenantId, guestId, subjectType, subjectRef])
  @@index([tenantId, guestId])
}

// ---------------------------------------------------------------------------
// Guest hub — Crew graph
// ---------------------------------------------------------------------------
model Crew {
  id           String   @id @default(uuid())
  tenantId     String
  name         String?
  ownerGuestId String
  createdAt    DateTime @default(now())

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  members    CrewMember[]
  affinities CrewAffinity[]
  bookings   Booking[]

  @@index([tenantId])
}

model CrewMember {
  tenantId String
  crewId   String
  guestId  String
  role     String @default("member")

  crew  Crew  @relation(fields: [crewId], references: [id])
  guest Guest @relation(fields: [guestId], references: [id])

  @@id([crewId, guestId])
  @@index([tenantId, crewId])
}

model CrewAffinity {
  id           String      @id @default(uuid())
  tenantId     String
  crewId       String
  subjectType  SubjectType
  subjectRef   String
  blendedScore Float
  confidence   Float       @default(0.5)

  crew Crew @relation(fields: [crewId], references: [id])

  @@unique([tenantId, crewId, subjectType, subjectRef])
  @@index([tenantId, crewId])
}

// ---------------------------------------------------------------------------
// Guest hub — Entitlements / Loyalty / Trust
// ---------------------------------------------------------------------------
enum EntitlementKind {
  perk
  ticket
  loyalty_credit
}

model Entitlement {
  id        String          @id @default(uuid())
  tenantId  String
  guestId   String
  kind      EntitlementKind
  state     String          @default("active")
  expiresAt DateTime?
  createdAt DateTime        @default(now())

  guest Guest @relation(fields: [guestId], references: [id])

  @@index([tenantId, guestId])
}

model TrustEvent {
  id        String   @id @default(uuid())
  tenantId  String
  guestId   String
  kind      String // no_show | positive | ...
  weight    Float    @default(1)
  createdAt DateTime @default(now())

  @@index([tenantId, guestId])
}

// ---------------------------------------------------------------------------
// Ops hub — Venues / Inventory / Bookings / Payments / Tab
// ---------------------------------------------------------------------------
model Venue {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  city        String?
  floorMapRef String?
  createdAt   DateTime @default(now())

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  inventory Inventory[]
  bookings  Booking[]

  @@index([tenantId])
}

enum InventoryKind {
  table
  ticket
}

model Inventory {
  id       String        @id @default(uuid())
  tenantId String
  venueId  String
  kind     InventoryKind
  label    String?
  capacity Int           @default(1)
  minSpend Int? // minor units (cents)
  deposit  Int? // minor units (cents)

  venue    Venue     @relation(fields: [venueId], references: [id])
  bookings Booking[]

  @@index([tenantId, venueId])
}

enum BookingStatus {
  held
  confirmed
  seated
  closed
  cancelled
}

model Booking {
  id             String        @id @default(uuid())
  tenantId       String
  venueId        String
  guestId        String
  crewId         String?
  inventoryId    String?
  status         BookingStatus @default(held)
  date           DateTime
  partySize      Int           @default(1)
  attributionId  String?
  idempotencyKey String?
  createdAt      DateTime      @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  venue     Venue      @relation(fields: [venueId], references: [id])
  guest     Guest      @relation(fields: [guestId], references: [id])
  crew      Crew?      @relation(fields: [crewId], references: [id])
  inventory Inventory? @relation(fields: [inventoryId], references: [id])
  payments  Payment[]
  tab       Tab?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, venueId])
  @@index([tenantId, guestId])
}

model Payment {
  id             String      @id @default(uuid())
  tenantId       String
  bookingId      String
  stripePiId     String?     @unique
  amount         Int // minor units (cents)
  currency       String      @default("usd")
  kind           PaymentKind @default(crew_share)
  splitGroupId   String?
  payerGuestId   String?
  status         String      @default("pending")
  idempotencyKey String?
  createdAt      DateTime    @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, bookingId])
}

model Tab {
  id        String    @id @default(uuid())
  tenantId  String
  bookingId String    @unique
  total     Int       @default(0) // minor units (cents)
  currency  String    @default("usd")
  lineItems Json?
  closedAt  DateTime?
  createdAt DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

// ---------------------------------------------------------------------------
// Marketing hub — Entities / Attribution / Audiences / Campaigns
// ---------------------------------------------------------------------------
enum EntityKind {
  artist
  event
  venue
}

model Entity {
  id           String     @id @default(uuid())
  kind         EntityKind
  name         String
  externalRefs Json?
  metadata     Json?
  createdAt    DateTime   @default(now())

  @@index([kind])
}

model AttributionLink {
  id         String   @id @default(uuid())
  tenantId   String
  venueId    String?
  campaignId String?
  // Promoter tracking (W6 pull-forward): a promoter is a creator whose links
  // carry attribution — same rails as campaigns, per-person accounting.
  promoterId String?
  code       String   @unique
  createdAt  DateTime @default(now())

  promoter Promoter? @relation(fields: [promoterId], references: [id])

  @@index([tenantId])
  @@index([tenantId, promoterId])
}

model Promoter {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  contact   String? // phone/email/IG handle
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  links AttributionLink[]

  @@index([tenantId])
}

model Audience {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  predicates Json
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

model Campaign {
  id         String   @id @default(uuid())
  tenantId   String
  audienceId String?
  channel    String   @default("klaviyo")
  status     String   @default("queued")
  createdAt  DateTime @default(now())

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Cross-cutting — Metering
// ---------------------------------------------------------------------------
model UsageEvent {
  id             String   @id @default(uuid())
  tenantId       String
  kind           String // booking | api_call | mcp_call
  billableAmount Int      @default(0) // minor units (cents)
  occurredAt     DateTime @default(now())
  // W7 take-rate dimensions: which acquisition path produced the booking and
  // which venue campaign gets the attribution receipt.
  path           String? // app | venue_link
  campaignId     String?
  bookingId      String?

  @@index([tenantId, kind])
  @@index([tenantId, path])
}

// ---------------------------------------------------------------------------
// Ops — Booking status transition ledger (append-only). Records every
// held->confirmed->seated->closed/cancelled move so no-show / cancel / turn
// TIMING is measured, not inferred from the booking's current status alone.
// ---------------------------------------------------------------------------
model BookingStatusEvent {
  id         String         @id @default(uuid())
  tenantId   String
  bookingId  String
  fromStatus BookingStatus?
  toStatus   BookingStatus
  reason     String?
  at         DateTime       @default(now())

  @@index([tenantId, bookingId])
  @@index([tenantId, at])
}

// ---------------------------------------------------------------------------
// Talent — a booked artist engagement at a venue on a date, with the modeled
// booking cost (minor units). Enables exact talent ROI: revenue on the
// (venueId, date) night minus the same-weekday baseline, net of `cost`.
// ---------------------------------------------------------------------------
model TalentEngagement {
  id        String   @id @default(uuid())
  tenantId  String
  venueId   String
  entityId  String // Entity(kind=artist)
  date      DateTime
  cost      Int? // talent fee, minor units (cents)
  status    String   @default("booked") // booked | confirmed | cancelled
  createdAt DateTime @default(now())

  @@index([tenantId, venueId, date])
  @@index([tenantId, entityId])
}

// ---------------------------------------------------------------------------
// Cross-cutting — Idempotency ledger (shared across instances; survives restart)
// Backs the idempotency interceptor: a mutating request records its key here so
// a retry with the same (tenantId, key) is a no-op / returns the prior outcome.
// ---------------------------------------------------------------------------
model IdempotencyRecord {
  id         String   @id @default(uuid())
  tenantId   String
  key        String
  method     String
  path       String
  statusCode Int?
  response   Json?
  createdAt  DateTime @default(now())

  @@unique([tenantId, key])
  @@index([tenantId, createdAt])
}

// ---------------------------------------------------------------------------
// Identity spine (P1) — the cross-tenant identity of a real person, independent
// of any tenant. Per-tenant Guest rows resolve to a GlobalGuest via verified
// identifiers. This is the object the "venues see rich guest intelligence" moat
// needs: a venue never reads another tenant's guest rows — it reads a CONSENTED,
// scoped PROJECTION derived through the spine (see VenueProjectionGrant).
// ---------------------------------------------------------------------------
model GlobalGuest {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  guests      Guest[]
  projections VenueProjectionGrant[]
}

// A guest (via their global spine) consents to a specific venue tenant seeing a
// SCOPED projection of their cross-tenant affinity. Enforced at read time by the
// projection service — the only sanctioned path for cross-tenant intelligence.
model VenueProjectionGrant {
  id              String    @id @default(uuid())
  globalGuestId   String
  granteeTenantId String // the venue tenant allowed to read the projection
  scope           String    @default("affinity:summary") // what may be projected
  grantedAt       DateTime  @default(now())
  revokedAt       DateTime?

  globalGuest GlobalGuest @relation(fields: [globalGuestId], references: [id])

  @@unique([globalGuestId, granteeTenantId, scope])
  @@index([granteeTenantId])
  @@index([globalGuestId])
}

// ---------------------------------------------------------------------------
// Durable evidence outbox (P1) — transactional outbox. The evidence row and an
// outbox row are written in the SAME transaction; a relay delivers outbox rows
// to the bus/Pub/Sub at-least-once and survives restarts. Replaces the
// fire-and-forget in-memory publish (which was at-most-once with silent loss).
// ---------------------------------------------------------------------------
model EvidenceOutbox {
  id          String    @id @default(uuid())
  tenantId    String
  topic       String    @default("evidence")
  payload     Json
  dedupeKey   String
  attempts    Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([publishedAt, createdAt])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Ops — Split-group funding state (captain guarantee). Ported from the
// 2026-07-23 Supabase design spike. A SplitGroup is the FUNDING axis of a
// booking's split-pay: the captain authorizes the FULL total up front (the
// guarantee), crew shares are captured individually, and at the funding
// deadline the captain's remainder is captured for whatever is unfunded.
// Deliberately a SEPARATE axis from BookingStatus (floor state) — a booking can
// be seated while still partially funded. Payments join by splitGroupId VALUE
// (no FK: pre-existing Payment rows carry ad-hoc split-group UUIDs with no
// parent row, so a constraint would break on existing data).
// ---------------------------------------------------------------------------
enum PaymentKind {
  captain_authorization
  crew_share
  captain_remainder
  refund
}

enum FundingState {
  pending
  authorized
  partially_funded
  funded
  settled
  expired
}

model SplitGroup {
  id                String       @id @default(uuid())
  tenantId          String
  bookingId         String
  captainGuestId    String
  totalAmount       Int // minor units (cents)
  fundedAmount      Int          @default(0) // captured crew_share + captain_remainder
  state             FundingState @default(pending)
  fundingDeadlineAt DateTime?
  captainPiId       String? // the captain's full-total authorization PI
  createdAt         DateTime     @default(now())

  events SplitGroupEvent[]

  @@index([tenantId, bookingId])
  @@index([tenantId, state])
}

// Append-only funding-state ledger — mirrors BookingStatusEvent so funding
// TIMING (when a group became funded, when the captain was drawn on) is
// measured, not inferred.
model SplitGroupEvent {
  id           String        @id @default(uuid())
  tenantId     String
  splitGroupId String
  fromState    FundingState?
  toState      FundingState
  reason       String?
  at           DateTime      @default(now())

  splitGroup SplitGroup @relation(fields: [splitGroupId], references: [id])

  @@index([tenantId, splitGroupId])
}

// ---------------------------------------------------------------------------
// Ops — Event Outlook (rules engine v1). Ported from the 2026-07-23 Supabase
// design spike; MVP subsystem 8. One row per (tenant, venue, night): a 0–100
// composite score over seven weighted factors (demand pace 20, revenue/margin
// 20, inventory yield 15, audience quality 15, payment certainty 10, marketing
// response 10, ops readiness 10). `factors` stores the per-factor 0–1 breakdown
// plus raw inputs so every score is explainable; `weightsVersion` pins the
// rule set so scores stay comparable across recomputes.
// ---------------------------------------------------------------------------
model EventOutlook {
  id             String   @id @default(uuid())
  tenantId       String
  venueId        String
  date           DateTime
  score          Float // 0–100 composite
  factors        Json // { factors: {..0–1..}, inputs: {..raw..} }
  weightsVersion String   @default("v1-20/20/15/15/10/10/10")
  computedAt     DateTime @default(now())

  @@unique([tenantId, venueId, date])
  @@index([tenantId, venueId])
}

// ---------------------------------------------------------------------------
// Ops — Operator action-outcome ledger. Ported from the 2026-07-23 Supabase
// design spike; MVP subsystems 9–10. Every recommendation surfaced to an
// operator (from rules, a model, an agent, or the operator themselves) is a
// row that moves proposed → approved/rejected → executed → measured, with the
// measured `outcome` closing the loop. Revenue-prompts and the Event Outlook
// are natural proposal sources.
// ---------------------------------------------------------------------------
enum OperatorActionSource {
  rules
  model
  operator
  agent
}

enum OperatorActionStatus {
  proposed
  approved
  rejected
  executed
  measured
}

model OperatorAction {
  id             String               @id @default(uuid())
  tenantId       String
  venueId        String?
  actionType     String // e.g. midweek_menu | attach_prompt | comp_offer | staffing
  target         Json? // what the action points at (bookingId, category, segment…)
  reason         String?
  expectedImpact Json? // e.g. { revenueCents: 40000, metric: "attach_rate" }
  confidence     Float? // 0–1, proposer's confidence
  source         OperatorActionSource @default(rules)
  status         OperatorActionStatus @default(proposed)
  outcome        Json? // measured result, closes the loop
  proposedAt     DateTime             @default(now())
  decidedAt      DateTime?
  executedAt     DateTime?
  measuredAt     DateTime?

  @@index([tenantId, status])
  @@index([tenantId, venueId])
}
