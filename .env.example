# --- Core ---
NODE_ENV=development
PORT=3000

# --- Postgres (Cloud SQL / AlloyDB in prod; docker-compose locally) ---
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas?schema=public

# --- Redis (Memorystore in prod; docker-compose locally) ---
REDIS_URL=redis://localhost:6379

# --- Evidence bus ---
# EVIDENCE_BUS=memory (local) | pubsub (GCP)
EVIDENCE_BUS=memory
GCP_PROJECT_ID=
PUBSUB_EVIDENCE_TOPIC=atlas-evidence

# --- Connector credentials (stubbed by default; leave blank for stub mode) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URL=
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URL=
# Apple Music: EITHER a pre-minted developer token, OR the signing trio below
# (Team ID + Key ID + the .p8 MusicKit key, base64-encoded) to mint it server-side.
APPLE_MUSIC_DEVELOPER_TOKEN=
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
KLAVIYO_API_KEY=
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Concerts artist-events sources (join to the taste graph). Stub until set.
TICKETMASTER_API_KEY=
BANDSINTOWN_APP_ID=

# --- Auth (dev shortcut: trust X-Tenant-Id / X-Scopes headers when true) ---
DEV_TRUST_HEADERS=true
